# ──────────────────────────────────────────────────────────────────────
# Variables de entorno para despliegue en OCI
# Copia este archivo a .env.production y reemplaza los valores marcados.
#   cp .env.production.example .env.production
#   nano .env.production
# ──────────────────────────────────────────────────────────────────────

# ─── Postgres (contenedor `db`) ───────────────────────────────────────
POSTGRES_USER=scholar
POSTGRES_PASSWORD=CAMBIAR_ESTE_PASSWORD
POSTGRES_DB=scholar

# ─── Conexión desde la app al contenedor `db` ─────────────────────────
# Host = `db` (nombre del servicio en docker-compose). Debe coincidir con
# POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB de arriba.
DATABASE_URL=postgresql://scholar:CAMBIAR_ESTE_PASSWORD@db:5432/scholar?schema=public

# ─── Auth.js v5 ───────────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
AUTH_SECRET=GENERAR_CON_openssl_rand_base64_32

# URL pública de la app (la verán los usuarios).
# Para el piloto sin dominio: http://<IP_PUBLICA_OCI>
# Al migrar a HTTPS con DuckDNS: https://anahuac-scholar.duckdns.org
AUTH_URL=http://CAMBIAR_POR_IP_PUBLICA
